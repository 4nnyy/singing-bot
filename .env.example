# Discord Developer Portal se milega (Bot tab > Reset Token)
DISCORD_TOKEN=your_bot_token_here

# Discord Developer Portal > General Information > Application ID
CLIENT_ID=your_application_id_here

# Optional: testing ke liye apne server ka ID daalo (instant command update).
# Isko khali/hataoge toh commands globally deploy honge (live hone mein ~1 hour lag sakta hai)
GUILD_ID=your_test_server_id_here
